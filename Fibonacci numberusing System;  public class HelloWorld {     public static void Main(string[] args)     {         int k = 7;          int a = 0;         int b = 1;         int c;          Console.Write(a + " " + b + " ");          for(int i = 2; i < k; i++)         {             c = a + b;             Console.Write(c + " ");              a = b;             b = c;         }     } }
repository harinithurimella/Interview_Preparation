using System;

public class HelloWorld
{
    public static void Main(string[] args)
    {
        int k = 7;

        int a = 0;
        int b = 1;
        int c;

        Console.Write(a + " " + b + " ");

        for(int i = 2; i < k; i++)
        {
            c = a + b;
            Console.Write(c + " ");

            a = b;
            b = c;
        }
    }
}
