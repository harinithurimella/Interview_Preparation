using System;

public class HelloWorld
{
    public static void Main(string[] args)
    {
        int number = 153;
        int temp = number;
        int sum = 0;
        
        while(temp > 0){
           int value = temp % 10;
            sum += value * value  * value;
            temp = temp/10;
            
        }
        Console.WriteLine(sum == number ? "Armstrong" : "Not Armstrong");
        
        
       

        
    }
}
